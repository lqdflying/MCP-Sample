# GitHub Personal Access Token
#
# READ-ONLY tools (read_file, list_directory, search_code, get_diff, etc.):
#   Classic token:      'public_repo' (public) or 'repo' (private)
#   Fine-grained:       Contents: Read, Metadata: Read
#
# WRITE tools (push_files, create_branch, create_pull_request, etc.):
#   Classic token:      'repo' scope (includes all write access)
#   Fine-grained:       Contents: Read+Write, Metadata: Read,
#                       Pull requests: Read+Write,
#                       Actions: Read+Write  (only if using trigger_workflow)
#
# Set MCP_READ_ONLY=true below if your token only has read permissions.
GITHUB_PAT=ghp_your_token_here

# MCP API Token — required for authenticating clients to this MCP server
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Auth mode:
# - token: static token only (MCP_API_TOKEN required)
# - oauth: GitHub OAuth only (MCP_API_TOKEN ignored)
# - both: token + GitHub OAuth (MCP_API_TOKEN required)
MCP_AUTH_MODE=both

# Auth audit log switch:
# - true: log auth decisions (method, oauth login, allowlist result), never logs token values
# - false: disable auth audit logs
MCP_AUTH_AUDIT_LOG=true

MCP_API_TOKEN=your_secret_mcp_token_here

# Optional GitHub OAuth settings (enable dual auth: token OR GitHub OAuth)
# If one of these is set, all three must be set.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Public base URL for this MCP server (used for OAuth callbacks/metadata), e.g. https://mcp.example.com
BASE_URL=

# Optional OAuth scopes (comma-separated). Keep least privilege when possible.
# Default when omitted: read:user
GITHUB_OAUTH_SCOPES=read:user

# REQUIRED for personal-only OAuth access — comma-separated GitHub logins, e.g. your-username
# If left empty, any valid GitHub account can authenticate via OAuth (open to all users).
# Set this to your own GitHub login to restrict OAuth sign-in to your account only.
ALLOWED_GITHUB_LOGINS=

# Session mode switch:
# - true (default): stateless — new transport per request, survives restarts, no stale sessions.
#                   Recommended for request/response tools (all current tools).
# - false: stateful — enables SSE event replay via Redis so clients can resume a dropped
#                     SSE stream using Last-Event-ID. Requires Upstash Redis vars below.
#                     Use this when adding long-running streaming tools.
#                     Note: sessions are in-memory, so clients must re-connect after restarts.
MCP_STATELESS=true

# Upstash Redis — required only when MCP_STATELESS=false.
# Both vars must be set together. Copy from your Upstash console → Redis → Details tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Read-only mode — set to true if your GITHUB_PAT only has read permissions.
# When true, all write/PR/issue/workflow tools are disabled at startup
# (push_files, create_branch, delete_file, create_pull_request, merge_pull_request,
#  add_pr_comment, create_issue, trigger_workflow, list_workflow_runs).
# Read tools (read_file, search_code, get_diff, list_branches, etc.) are always available.
MCP_READ_ONLY=false

# Server configuration
HOST=0.0.0.0
PORT=8000
